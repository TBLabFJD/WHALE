// TODO nf-core: Once you have added the required tests, please run the following command to build this file:
// nf-core modules test dorado_basecaller
nextflow_process {

    name "Test Process WHATSHAP_SPLIT"
    script "../main.nf"
    process "WHATSHAP_SPLIT"

    tag "modules"
    tag "modules_nfcore"
    tag "whatshap_split"

    // TODO nf-core: Change the test name preferably indicating the test-data and file-format used
    test("whatshap split - global bam - tsv --> h1 - h2 - unassigned") {
        

        when {
            process {
                """
                input[0] = [
                    [ id: 'test_sample', single_end: false ],
                    file("https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/homo_sapiens/nanopore/bam/test.sorted.phased.bam", checkIfExists: true),
                    file("https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/genomics/homo_sapiens/nanopore/bam/test.sorted.phased.bam.bai", checkIfExists: true)
                ]

                input[1] = [
                    [ id: 'test_sample', single_end: false ],
                    file("${moduleDir}/tests/data/test_reads.tsv", checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
                //TODO nf-core: Add all required assertions to verify the test output.
                // See https://nf-co.re/docs/contributing/tutorials/nf-test_assertions for more information and examples.
            )
        }

    }
}
