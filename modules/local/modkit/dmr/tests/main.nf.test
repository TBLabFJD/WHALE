nextflow_process {

    name "Test Process MODKIT_DMR"
    script "../main.nf"
    process "MODKIT_DMR"

    tag "modules"
    tag "modules_local"
    tag "modkit"
    tag "modkit_dmr"

    test("modkit_dmr - h1_vs_h2") {
        
        when {
            process {
                """
                // Replicamos la estructura exacta que genera tu sub-workflow después del .join() y el .map{}
                input[0] = [
                    [ id: 'test_sample', single_end: false ],                         // meta
                    file("ruta/a/tus/datos/test_h1.bed.gz", checkIfExists: true),     // h1_bed (bedMethyl)
                    file("ruta/a/tus/datos/test_h1.bed.gz.tbi", checkIfExists: true), // h1_tbi
                    file("ruta/a/tus/datos/test_h2.bed.gz", checkIfExists: true),     // h2_bed (bedMethyl)
                    file("ruta/a/tus/datos/test_h2.bed.gz.tbi", checkIfExists: true)  // h2_tbi
                ]
                
                input[1] = [
                    [ id: 'hg38' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.fai', checkIfExists: true)
                ]
                """
            }
        }

        then {
            assertAll(
                // 1. Verificamos que el comando de Bash haya terminado sin errores (Exit Code 0)
                { assert process.success },
                
                // 2. Tomamos la fotografía de los outputs (el archivo bed de DMRs)
                { assert snapshot(process.out).match() }
            )
        }

    }
}