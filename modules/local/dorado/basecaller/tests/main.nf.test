// TODO nf-core: Once you have added the required tests, please run the following command to build this file:
// nf-core modules test dorado_basecaller
nextflow_process {

    name "Test Process DORADO_BASECALLER"
    script "../main.nf"
    process "DORADO_BASECALLER"

    tag "modules"
    tag "modules_nfcore"
    tag "dorado_basecaller"

    // TODO nf-core: Change the test name preferably indicating the test-data and file-format used
    test("dorado_basecaller - pod5") {
        
        setup {
            run("DORADO_DOWNLOAD") {
                script "../../download/main.nf"
                process {
                    """
                    input[0] = Channel.of([
                        [ id : 'test_sample' ],
                        "dna_r10.4.1_e8.2_400bps_hac@v5.2.0" 
                    ])
                    """
                }
            }
        }

        when {
            process {
                """
                input[0] = Channel.of([
                    [ id : 'test_sample' ],
                    file("https://github.com/nf-core/test-datasets/raw/methylong/v2.0.0/test_data/test_pod5/HG002_Chr1_5mb-7mb.pod5", checkIfExists: true) 
                ])
                input[1] = Channel.of([
                    [ id : 'hg38' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true)
                ])
                input[2] = Channel.of([
                    [ id : 'hg38' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.fai', checkIfExists: true)
                ])
                input[3] = "cpu"
                input[4] = DORADO_DOWNLOAD.out.model
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
                //TODO nf-core: Add all required assertions to verify the test output.
                // See https://nf-co.re/docs/contributing/tutorials/nf-test_assertions for more information and examples.
            )
        }

    }
}
