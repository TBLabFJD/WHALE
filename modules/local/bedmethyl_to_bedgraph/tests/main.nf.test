// TODO nf-core: Once you have added the required tests, please run the following command to build this file:
// nf-core modules test bedmethyl_to_bedgraph
nextflow_process {

    name "Test Process BEDMETHYL_TO_BEDGRAPH"
    script "../main.nf"
    process "BEDMETHYL_TO_BEDGRAPH"

    tag "modules"
    tag "modules_nfcore"
    tag "bedmethyl_to_bedgraph"

    // TODO nf-core: Change the test name preferably indicating the test-data and file-format used
    test("bedmethyl_to_bedgraph - bedgz") {
        
    setup {
        run("DORADO_DOWNLOAD") {
            script "../../dorado/download/main.nf"
            process {
                """
                input[0] = Channel.of([
                    [ id : 'test_sample' ],
                    "dna_r10.4.1_e8.2_400bps_hac@v5.2.0" 
                ])
                """
            }
        }

        run("DORADO_BASECALLER") {
            script "../../dorado/basecaller/main.nf"
            process {
                """
                // 1. AÑADIMOS DOS MUESTRAS (Reusamos el mismo archivo para no descargar de más)
                input[0] = Channel.of(
                    [ [ id : 'sample1' ], file("https://github.com/nf-core/test-datasets/raw/methylong/v2.0.0/test_data/test_pod5/HG002_Chr1_5mb-7mb.pod5", checkIfExists: true) ],
                    [ [ id : 'sample2' ], file("https://github.com/nf-core/test-datasets/raw/methylong/v2.0.0/test_data/test_pod5/HG002_Chr1_7mb-10mb.pod5", checkIfExists: true) ]
                )
                input[1] = Channel.of([
                    [ id : 'hg38' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true)
                ]).first()
                input[2] = Channel.of([
                    [ id : 'hg38' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.fai', checkIfExists: true)
                ]).first()
                input[3] = params.device
                input[4] = DORADO_DOWNLOAD.out.model.first()
                """
            }
        }

        run("SAMTOOLS_SORT") {
            script "../../../nf-core/samtools/sort/main.nf"
            process {
                """
                input[0] = DORADO_BASECALLER.out.bam
                input[1] = Channel.of([
                    [ id : 'hg38' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true)
                ]).first()
                input[2] = "bai"
                """
            }
        }

        run("SAMTOOLS_MERGE") {
            script "../../../nf-core/samtools/merge/main.nf"
            process {
                """
                input[0] = SAMTOOLS_SORT.out.bam
                    .map { meta, bam -> bam } 
                    .collect()
                    .map { bams -> [ [id:'all_samples'], bams ] }
                input[1] = Channel.of([
                    [ id: 'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.fai', checkIfExists: true),
                    []
                ])
                """
            }
        }

        run("SAMTOOLS_INDEX") {
            script "../../../nf-core/samtools/index/main.nf"
            process {
                """
                input[0] = SAMTOOLS_MERGE.out.bam
                """
            }
        }

        run("MODKIT_PILEUP") {
            script "../../../nf-core/modkit/pileup/main.nf"
            process {
                """
                input[0] = SAMTOOLS_MERGE.out.bam.join(SAMTOOLS_INDEX.out.bai)
                input[1] = Channel.of([
                    [ id: 'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.fai', checkIfExists: true)
                ])
                input[2] = Channel.of([
                    [ id: 'none' ],
                    []
                ])
                """
            }
        }
    }

        when {
            process {
                """
                // TODO nf-core: define inputs of the process here. Example:
                
                input[0] = MODKIT_PILEUP.out.bedgz
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
                //TODO nf-core: Add all required assertions to verify the test output.
                // See https://nf-co.re/docs/contributing/tutorials/nf-test_assertions for more information and examples.
            )
        }

    }
}